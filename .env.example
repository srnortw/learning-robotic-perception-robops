# Copy this to .env and fill in real values — NEVER commit .env to git

# ── AWS ──────────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_DEFAULT_REGION=eu-central-1
ROBOPS_S3_BUCKET=my-perception-robops-data-2026-688567275774-eu-central-1-an

# ── ECR ──────────────────────────────────────────────────────────────────────
ECR_REGISTRY=688567275774.dkr.ecr.eu-central-1.amazonaws.com
ECR_REPO_TRAINING=688567275774.dkr.ecr.eu-central-1.amazonaws.com/robops/training
ECR_REPO_INFERENCE=688567275774.dkr.ecr.eu-central-1.amazonaws.com/robops/inference
ECR_REPO_ROS2_STACK=688567275774.dkr.ecr.eu-central-1.amazonaws.com/robops/ros2-stack

# ── MongoDB Atlas ─────────────────────────────────────────────────────────────
# Get this from Atlas → Connect → Drivers → Python
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/robops?retryWrites=true&w=majority

# ── DagsHub (MLflow) ─────────────────────────────────────────────────────────
DAGSHUB_USERNAME=your-dagshub-username
DAGSHUB_TOKEN=your-dagshub-token
MLFLOW_TRACKING_URI=https://dagshub.com/your-dagshub-username/robops_perception.mlflow

# ── Discord (Phase D audit notifications) ────────────────────────────────────
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your-webhook-url

# ── GitHub Actions (set these as repo secrets, not here) ─────────────────────
# GITHUB_TOKEN — auto-provided by Actions
